"""
Student Agent Configuration and Environment Setup

This file contains environment variable templates and configuration
for running the Student Agent.
"""

# DISCORD CONFIGURATION
# Get these from your Discord server settings and developer portal

# Guild (Server) ID
DISCORD_GUILD_ID=1478915631016448020

# Channel IDs for monitoring and participation
ANNOUNCEMENTS_ID=1480106512813654036
TOPIC_DISCUSSION_ID=1479995367754960946
GENERAL_ID=1478915632723398961

# Discord Bot Token for Student Agent
# Create this in Discord Developer Portal > Applications > Your App > Token
STUDENT_DISCORD_TOKEN=your_bot_token_here

# LLM CONFIGURATION
# Ollama local LLM provider

# Ollama server endpoint
OLLAMA_HOST=http://chucks-mac-studio:11434

# Model to use for response generation
# Options: qwen3-14b-edu-clean, qwen3-14b-edu-strict
OLLAMA_MODEL=qwen3-14b-edu-clean

# LOGGING
# Set to DEBUG for verbose output
LOG_LEVEL=INFO
