{
  "name": "openclaw-agents-481-07",
  "version": "1.0.0",
  "type": "module",
  "description": "Standardized Safe Setup for AI Discussions - CPSC 481.07",
  "scripts": {
    "setup": "npx openclaw setup",
    "check": "node scripts/validate-setup.js",
    "start": "npx openclaw gateway --verbose",
    "onboard": "npx openclaw onboard",
    "logs": "powershell -Command \"Get-Content -Path ./state/logs/openclaw.log -Wait\"",
    "test:llm": "node scripts/test-qwen3.js",
    "studio": "npx openclaw-studio",
    "gateway": "powershell -File ./run-openclaw.ps1",
    "config:validate": "node -e \"const c=require('./openclaw.json');const p=c.models.providers;console.log('Default model:',c.agents.defaults.model.primary);Object.entries(p).forEach(([k,v])=>{console.log('Provider:',k,'→',v.baseUrl);fetch(v.baseUrl.replace(/\\/v1$/,'')).then(r=>console.log(' ',k,'reachable ('+r.status+')')).catch(e=>console.log(' ',k,'UNREACHABLE:',e.message))})\"",
    "config:backup": "node -e \"const fs=require('fs');const ts=new Date().toISOString().replace(/[:T]/g,'-').slice(0,19);fs.copyFileSync('openclaw.json','openclaw.json.bak.'+ts);console.log('Backed up to openclaw.json.bak.'+ts)\"",
    "env": "powershell -Command \"& ./run-openclaw.ps1 version\""
  },
  "dependencies": {
    "openclaw": "^2026.4.16",
    "openclaw-studio": "^0.0.12"
  }
}
