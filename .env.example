# Copy this file to .env (npm run setup does this once) and fill in real values.

# OpenCLAW path isolation — keep state in this project folder
OPENCLAW_CONFIG_PATH=./openclaw.json
OPENCLAW_STATE_DIR=./.openclaw

# LLM provider keys
OPENAI_API_KEY=your_openai_key_here
GROQ_API_KEY=your_groq_api_key_here

# Web search plugin
EXA_API_KEY=your_exa_api_key_here

# Gateway auth token (generate with: openssl rand -hex 24)
OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here

# Discord bot credentials (shared fallback token)
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_APP_ID=your_discord_application_id_here
DISCORD_GUILD_ID=your_discord_server_id_here

# Per-agent Discord bot tokens
INSTRUCTOR_DISCORD_TOKEN=your_instructor_bot_token_here
STUDENT_DISCORD_TOKEN=your_student_bot_token_here
TA_DISCORD_TOKEN=your_ta_bot_token_here

# Course server routing IDs
INFO_ANNOUNCEMENTS_CHANNEL_ID=your_announcements_channel_id_here
ACTIVE_TOPICS_CATEGORY_ID=your_active_topics_category_id_here
TOPIC_DISCUSSION_ID=your_topic_discussion_channel_id_here
GENERAL_ID=your_general_channel_id_here
ARCHIVED_CATEGORY_ID=your_archived_category_id_here
